# NEXT_PUBLIC_SANITY_PROJECT_ID=
# NEXT_PUBLIC_SANITY_DATASET=production
# NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Optional: for draft/preview or elevated reads (keep server-only)
# SANITY_API_READ_TOKEN=

# Webhook secret for POST /api/revalidate — Authorization: Bearer <secret>
# SANITY_REVALIDATE_SECRET=

# xAI — chat (`/api/chat`), TTS (`/api/chat/tts`), STT (`/api/chat/stt`)
XAI_API_KEY=
# Optional override — check https://docs.x.ai/docs/models for current IDs
XAI_MODEL=grok-2-latest
# Used automatically when the latest messages include image attachments (vision). Defaults to XAI_MODEL if unset.
# XAI_VISION_MODEL=grok-2-latest

# Serper — server-side web search tool (`webSearch` in `/api/chat`). https://serper.dev
SERPER_API_KEY=

# Local realtime voice proxy — browser connects here; the proxy adds Authorization for xAI Realtime (same machine as dev).
# Run in a second terminal: npm run voice-proxy  (requires XAI_API_KEY in env)
# NEXT_PUBLIC_XAI_VOICE_PROXY_WS=ws://127.0.0.1:8787
# Optional — defaults to grok-voice-think-fast-1.0 in scripts/xai-voice-proxy.mjs
# XAI_REALTIME_MODEL=grok-voice-think-fast-1.0
# XAI_VOICE_PROXY_PORT=8787

# Optional: canonical URL for metadata (recommended in production)
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
