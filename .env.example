# NEXT_PUBLIC_SANITY_PROJECT_ID=
# NEXT_PUBLIC_SANITY_DATASET=production
# NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Optional: for draft/preview or elevated reads (keep server-only)
# SANITY_API_READ_TOKEN=

# Webhook secret for POST /api/revalidate — Authorization: Bearer <secret>
# SANITY_REVALIDATE_SECRET=

# xAI — floating chat widget (`/api/chat`)
XAI_API_KEY=
# Optional override — check https://docs.x.ai/docs/models for current IDs
XAI_MODEL=grok-2-latest

# Optional: canonical URL for metadata (recommended in production)
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
